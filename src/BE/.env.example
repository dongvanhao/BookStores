# ─── Copy file này thành .env và điền giá trị thật ───────────────────────────
# .env KHÔNG được commit lên git (đã gitignore)
# .env.example ĐƯỢC commit — dùng để tài liệu hoá các biến cần thiết

# ─── SQL Server ───────────────────────────────────────────────────────────────
SA_PASSWORD=YourStrong@Password123

# ─── Connection String (local dev — không dùng Docker) ───────────────────────
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=BookStoreDB;User Id=sa;Password=YourStrong@Password123;TrustServerCertificate=True;Encrypt=False

# ─── JWT ─────────────────────────────────────────────────────────────────────
JwtOptions__Key=your-super-secret-key-must-be-at-least-32-characters-long
JwtOptions__Issuer=BookStore
JwtOptions__Audience=BookStore

# ─── MinIO container credentials ─────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── MinIO API config (ASP.NET Core env var binding) ─────────────────────────
# Trong Docker: Endpoint phải là tên service (minio:9000), không phải localhost
# Local dev: localhost:9000
MinioSettings__Endpoint=localhost:9000
MinioSettings__AccessKey=minioadmi
MinioSettings__SecretKey=minioadmi
MinioSettings__UseSsl=false

# ─── Admin Seed ───────────────────────────────────────────────────────────────
# Để trống hoặc xoá 2 dòng dưới để tắt seed
SeedSettings__AdminEmail=admin2@bookstore.com
SeedSettings__AdminPassword=Admin@12345
SeedSettings__AdminFullName=Administrator

# ─── Feature flags ────────────────────────────────────────────────────────────
ENABLE_SEED=true
