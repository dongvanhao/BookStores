{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "JwtOptions": {
    "Key": "",
    "Issuer": "BookStore",
    "Audience": "BookStore",
    "AccessExpiryMinutes": 15,
    "RefreshExpiryDays": 7
  },

  "Gemini": {
    "Enabled": false,
    "ApiKey": "",
    "Model": "gemini-2.5-flash",
    "MaxTokens": 300
  },

  "MinioSettings": {
    "Endpoint": "",
    "AccessKey": "",
    "SecretKey": "",
    "UseSsl": false,
    "Buckets": {
      "Books":   "books",
      "Authors": "authors",
      "Users":   "users"
    },
    "PresignedUrlExpirySeconds": 3600,
    "AllowedMimeTypes": [
      "image/jpeg", "image/png", "image/webp", "image/gif",
      "application/pdf"
    ],
    "MaxFileSizeBytes": 10485760
  },

  "AllowedHosts": "*",

  "AppSettings": {
    "ClientBaseUrl": "http://localhost:3000"
  }
}
